# Credenciais de acesso (login único da instância)
AUTH_USERNAME=
AUTH_PASSWORD=

# Segredo usado para assinar/validar o JWT de sessão
JWT_SECRET=

# Connection string do Postgres usado para registrar as specs carregadas
DATABASE_URL=

# Chave usada para criptografar (AES-256-GCM) as API keys dos provedores de IA
# armazenadas em ai_providers.api_key_encrypted. Precisa ser 32 bytes em base64,
# mesmo padrão de robustez do JWT_SECRET. Gere com: openssl rand -base64 32
AI_CONFIG_ENCRYPTION_KEY=

# Limites (conservadores, configuráveis) de consumo de tokens do chat de IA
AI_RATE_LIMIT_TOKENS_PER_HOUR=500000
AI_RATE_LIMIT_TOKENS_PER_DAY=5000000
